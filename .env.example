# ─── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Airtable ──────────────────────────────────────────────────────────────────
# Generate a Personal Access Token at: https://airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write, schema.bases:write, schema.bases:read
AIRTABLE_API_KEY=your_airtable_personal_access_token_here
# Leave blank until you run: python airtable_client.py --setup
AIRTABLE_BASE_ID=

# ─── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Gmail ─────────────────────────────────────────────────────────────────────
# Generate an App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=auralithdigital@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ─── Summary recipient ─────────────────────────────────────────────────────────
SUMMARY_EMAIL=support@auralithdigital.com
